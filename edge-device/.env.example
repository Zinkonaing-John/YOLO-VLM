# Edge Device Configuration
# Copy to .env and modify as needed

# ── Camera ──────────────────────────────────
CAMERA_SOURCE=0               # 0=USB, rtsp://..., or /path/to/video.mp4
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
USE_CSI=false                 # Set true for Jetson CSI cameras
CSI_SENSOR_ID=0

# ── Models ──────────────────────────────────
DET_MODEL_PATH=weights/best.engine       # Stage 1: detection (.engine or .pt)
CLS_MODEL_PATH=                          # Stage 2: classification (leave empty for det-only)
DET_CONFIDENCE=0.5
CLS_CONFIDENCE=0.5
DET_IMG_SIZE=640

# ── Server ──────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Cloud Sync (optional) ──────────────────
UPSTREAM_API_URL=                         # e.g. http://server:8000/api/v1/edge-inspect
UPSTREAM_UPLOAD_NG_ONLY=true

# ── MQTT (optional) ────────────────────────
MQTT_BROKER=                              # e.g. 192.168.1.100
MQTT_PORT=1883
MQTT_CLIENT_ID=jetson-edge-001

# ── Storage ─────────────────────────────────
MAX_STORED_IMAGES=5000                    # Auto-cleanup oldest when exceeded
